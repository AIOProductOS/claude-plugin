{
  "manifest_version": "0.2",
  "name": "aioproductos",
  "display_name": "AIOProductOS",
  "version": "0.15.9",
  "description": "Run your AIOProductOS product board, product brain, first-party analytics, and support inbox from Claude Desktop — over one typed customer record that joins revenue, feedback, work, and code.",
  "long_description": "AIOProductOS is a product operating system: one shared record per customer that joins revenue, customer feedback, product analytics, work, and code. This desktop extension connects Claude Desktop to your workspace over MCP with 71 tools — read AND write across the product spine: the board (create/move/delete tasks), the strategy-to-delivery ladder (ideas & votes, initiatives, features, OKRs, sprints, releases, pages, experiments, decisions), capture feedback as insights, compute revenue-weighted NPS/NRR/funnels/retention, review and revert AI artifacts, work the support inbox, comms channels and the identity graph. Authentication is a single personal access token generated in AIOProductOS → Settings → Tokens & Agents; the token is scoped to your org and every call respects your row-level permissions. The extension stores nothing locally — each tool call is one authenticated HTTPS request to the platform. Prefer a fully remote, OAuth 2.1 connection with no token to manage? Add the 65-tool hosted connector at https://platform.aioproductos.com/api/mcp instead.",
  "author": {
    "name": "AIOProductOS Inc.",
    "email": "office@aioproductos.com",
    "url": "https://aioproductos.com"
  },
  "homepage": "https://aioproductos.com/product/mcp",
  "documentation": "https://aioproductos.com/product/mcp",
  "support": "https://github.com/AIOProductOS/claude-plugin/issues",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AIOProductOS/claude-plugin"
  },
  "keywords": [
    "product-management",
    "product-operations",
    "productos",
    "analytics",
    "customer-feedback",
    "roadmap",
    "spine"
  ],
  "server": {
    "type": "node",
    "entry_point": "server/index.js",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/server/index.js"
      ],
      "env": {
        "PRODUCTOS_TOKEN": "${user_config.token}",
        "NO_UPDATE_NOTIFIER": "1"
      }
    }
  },
